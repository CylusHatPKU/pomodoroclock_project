  <property name="styleSheet">
   <string notr="true">QWidget#centralwidget {
    background-color: #f2f3f5;
}

QLabel {
    color: #202124;
}

QLabel#modeLabel {
    color: #1f2937;
}

QLabel#timeLabel {
    background-color: #ffffff;
    color: #111827;
    border: 1px solid #d0d5dd;
    border-radius: 8px;
}

QPushButton {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #cfd4dc;
    border-radius: 8px;
    padding: 8px 14px;
}

QPushButton:hover {
    background-color: #e8edf3;
}

QPushButton:pressed {
    background-color: #d8dee8;
}

QPushButton:disabled {
    color: #98a2b3;
    background-color: #edf0f3;
}

QSpinBox {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #cfd4dc;
    border-radius: 6px;
    padding: 4px 8px;
}

QListWidget {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #d0d5dd;
    border-radius: 8px;
    padding: 4px;
}

QListWidget::item {
    padding: 6px;
}

QListWidget::item:selected {
    background-color: #e8edf3;
    color: #111827;
}

QLabel#nextStagePanel {
    background-color: #ffffff;
    border: 1px solid #d0d5dd;
    border-radius: 8px;
}</string>
